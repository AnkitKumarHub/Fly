# Database
DATABASE_URL=

# Auth
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Server
PORT=
NODE_ENV=

# URLs — required in production; localhost defaults apply in development only
FRONTEND_URL=
APP_URL=

# Cookies — COOKIE_SECURE defaults to true when NODE_ENV=production
COOKIE_SECURE=
COOKIE_SAMESITE=
# COOKIE_DOMAIN=.yourdomain.com

# Google OAuth (app login + Corsair integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Corsair SDK
CORSAIR_KEK=

# Gmail push webhooks (optional for local dev without Pub/Sub)
GMAIL_PUBSUB_TOPIC=

# AI agent
OPENAI_API_KEY=
OPENAI_MODEL=
AGENT_MAX_STEPS=
